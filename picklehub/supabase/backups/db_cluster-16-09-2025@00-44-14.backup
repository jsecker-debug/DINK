--
-- Name: session_payments Admin users can manage payment status; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Admin users can manage payment status" ON public.session_payments USING ((EXISTS ( SELECT 1
   FROM (public.club_memberships cm
     JOIN public.sessions s ON ((s.club_id = cm.club_id)))
  WHERE ((cm.user_id = auth.uid()) AND (cm.role = 'admin'::text) AND (s.id = session_payments.session_id)))));


--
-- Name: game_scores Admins can delete game scores; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Admins can delete game scores" ON public.game_scores FOR DELETE USING ((EXISTS ( SELECT 1
   FROM (public.sessions s
     JOIN public.club_memberships cm ON ((s.club_id = cm.club_id)))
  WHERE ((s.id = game_scores.session_id) AND (cm.user_id = auth.uid()) AND (cm.role = 'admin'::text) AND (cm.status = 'active'::text)))));


--
-- Name: club_invitations Anyone can read invitations by token; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can read invitations by token" ON public.club_invitations FOR SELECT USING (true);


--
-- Name: clubs Anyone can view active clubs; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can view active clubs" ON public.clubs FOR SELECT USING ((status = 'active'::text));


--
-- Name: clubs Authenticated users can create clubs; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Authenticated users can create clubs" ON public.clubs FOR INSERT TO authenticated WITH CHECK (true);


--
-- Name: club_invitations Club admins can manage invitations; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Club admins can manage invitations" ON public.club_invitations USING ((EXISTS ( SELECT 1
   FROM public.club_memberships
  WHERE ((club_memberships.club_id = club_invitations.club_id) AND (club_memberships.user_id = auth.uid()) AND (club_memberships.role = 'admin'::text) AND (club_memberships.status = 'active'::text)))));


--
-- Name: club_join_requests Club admins can update club requests; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Club admins can update club requests" ON public.club_join_requests FOR UPDATE USING ((EXISTS ( SELECT 1
   FROM public.club_memberships cm
  WHERE ((cm.club_id = club_join_requests.club_id) AND (cm.user_id = auth.uid()) AND (cm.role = 'admin'::text) AND (cm.status = 'active'::text)))));


--
-- Name: user_profiles Club admins can update member game stats; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Club admins can update member game stats" ON public.user_profiles FOR UPDATE USING ((EXISTS ( SELECT 1
   FROM (public.club_memberships cm1
     JOIN public.club_memberships cm2 ON ((cm1.club_id = cm2.club_id)))
  WHERE ((cm1.user_id = auth.uid()) AND (cm1.role = 'admin'::text) AND (cm1.status = 'active'::text) AND (cm2.user_id = user_profiles.id) AND (cm2.status = 'active'::text)))));


--
-- Name: club_join_requests Club admins can view club requests; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Club admins can view club requests" ON public.club_join_requests FOR SELECT USING ((EXISTS ( SELECT 1
   FROM public.club_memberships cm
  WHERE ((cm.club_id = club_join_requests.club_id) AND (cm.user_id = auth.uid()) AND (cm.role = 'admin'::text) AND (cm.status = 'active'::text)))));


--
-- Name: session_registrations Club members can access session registrations; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Club members can access session registrations" ON public.session_registrations USING ((EXISTS ( SELECT 1
   FROM (public.sessions s
     JOIN public.club_memberships cm ON ((s.club_id = cm.club_id)))
  WHERE ((s.id = session_registrations.session_id) AND (cm.user_id = session_registrations.user_id) AND (cm.status = 'active'::text))))) WITH CHECK ((EXISTS ( SELECT 1
   FROM (public.sessions s
     JOIN public.club_memberships cm ON ((s.club_id = cm.club_id)))
  WHERE ((s.id = session_registrations.session_id) AND (cm.user_id = cm.user_id) AND (cm.status = 'active'::text)))));


