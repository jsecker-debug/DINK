-- Name: game_scores Users can update game scores they created within session day or; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can update game scores they created within session day or" ON public.game_scores FOR UPDATE USING ((((created_by = auth.uid()) AND (date(created_at) = CURRENT_DATE)) OR (EXISTS ( SELECT 1
   FROM (public.sessions s
     JOIN public.club_memberships cm ON ((s.club_id = cm.club_id)))
  WHERE ((s.id = game_scores.session_id) AND (cm.user_id = auth.uid()) AND (cm.role = 'admin'::text) AND (cm.status = 'active'::text))))));


