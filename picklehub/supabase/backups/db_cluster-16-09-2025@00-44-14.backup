    target_id uuid,
    target_type text,
    data jsonb DEFAULT '{}'::jsonb,
    created_at timestamp with time zone DEFAULT now(),
    CONSTRAINT activities_target_type_check CHECK ((target_type = ANY (ARRAY['session'::text, 'participant'::text, 'game_result'::text, 'club'::text]))),
    CONSTRAINT activities_type_check CHECK ((type = ANY (ARRAY['session_created'::text, 'session_completed'::text, 'game_result'::text, 'member_joined'::text, 'member_left'::text, 'ranking_updated'::text, 'announcement'::text, 'general'::text, 'event'::text, 'tournament_result'::text])))
);


ALTER TABLE public.activities OWNER TO postgres;

